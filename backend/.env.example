PORT=3000
NODE_ENV=development

# Obrigatória para transcrição/tradução real
GROQ_API_KEY=sua_chave_groq_aqui

# Supabase é opcional: se não preencher, o backend usa cache em memória
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

TEMP_DIR=./temp
MAX_AUDIO_SIZE_MB=25
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
